
{
  "pipeline": {
    "name": "data-pipeline-etl-cd",
    "roleArn": "arn:aws:iam::603433800200:role/data-pipeline-codepipeline-role",
    "artifactStore": {
      "type": "S3",
      "location": "cicd-artifacts-603433800200-ap-south-1"
    },
    "stages": [
      {
        "name": "Source",
        "actions": [
          {
            "name": "GitHubSource",
            "actionTypeId": {
              "category": "Source",
              "owner": "AWS",
              "provider": "CodeStarSourceConnection",
              "version": "1"
            },
            "runOrder": 1,
            "configuration": {
              "ConnectionArn": "arn:aws:codeconnections:ap-south-1:603433800200:connection/dcfa3a2a-759f-489d-b868-1b6e80a16212",
              "FullRepositoryId": "ArBaghel/data-pipeline-cicd-demo",
              "BranchName": "main",
              "OutputArtifactFormat": "CODE_ZIP"
            },
            "outputArtifacts": [
              {
                "name": "SourceOutput"
              }
            ]
          }
        ]
      },
      {
        "name": "Build",
        "actions": [
          {
            "name": "BuildAndTest",
            "actionTypeId": {
              "category": "Build",
              "owner": "AWS",
              "provider": "CodeBuild",
              "version": "1"
            },
            "runOrder": 1,
            "configuration": {
              "ProjectName": "etl-customer-build"
            },
            "inputArtifacts": [
              {
                "name": "SourceOutput"
              }
            ],
            "outputArtifacts": [
              {
                "name": "BuildOutput"
              }
            ]
          }
        ]
      },
      {
        "name": "Deploy",
        "actions": [
          {
            "name": "DeployLambda",
            "actionTypeId": {
              "category": "Deploy",
              "owner": "AWS",
              "provider": "Lambda",
              "version": "1"
            },
            "runOrder": 1,
            "configuration": {
              "FunctionName": "etl-customer-s3-to-dynamodb"
            },
            "inputArtifacts": [
              {
                "name": "BuildOutput"
              }
            ]
          }
        ]
      }
    ],
    "version": 1
  }
}
