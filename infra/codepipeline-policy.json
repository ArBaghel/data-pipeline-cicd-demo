{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:GetObjectVersion",
        "s3:PutObject",
        "s3:GetBucketLocation",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::cicd-artifacts-603433800200-ap-south-1",
        "arn:aws:s3:::cicd-artifacts-603433800200-ap-south-1/*"
      ]
    },
    {
      "Effect": "Allow",
      "Action": [
        "codebuild:BatchGetBuilds",
        "codebuild:StartBuild"
      ],
      "Resource": "arn:aws:codebuild:ap-south-1:603433800200:project/etl-customer-build"
    },
    {
      "Effect": "Allow",
      "Action": "codestar-connections:UseConnection",
      "Resource": "arn:aws:codeconnections:ap-south-1:603433800200:connection/21d3a5b8-fe98-41e1-9ac7-4a430fcbdfdb"
    },
    {
      "Effect": "Allow",
      "Action": [
        "lambda:UpdateFunctionCode",
        "lambda:PublishVersion",
        "lambda:UpdateAlias",
        "lambda:GetFunction",
        "lambda:GetAlias",
        "lambda:GetFunctionConfiguration"
      ],
      "Resource": [
        "arn:aws:lambda:ap-south-1:603433800200:function:etl-customer-s3-to-dynamodb",
        "arn:aws:lambda:ap-south-1:603433800200:function:etl-customer-s3-to-dynamodb:*"
      ]
    },
    {
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": [
        "arn:aws:logs:ap-south-1:603433800200:log-group:/aws/codepipeline/data-pipeline-etl-cd",
        "arn:aws:logs:ap-south-1:603433800200:log-group:/aws/codepipeline/data-pipeline-etl-cd:log-stream:*"
      ]
    }
  ]
}
