{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadCustomerCsvFromS3",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::testingrawdata1",
        "arn:aws:s3:::testingrawdata1/*"
      ]
    },
    {
      "Sid": "WriteRecordsToDynamoDb",
      "Effect": "Allow",
      "Action": [
        "dynamodb:PutItem",
        "dynamodb:BatchWriteItem",
        "dynamodb:DescribeTable"
      ],
      "Resource": "arn:aws:dynamodb:ap-south-1:603433800200:table/etl-customer-table"
    },
    {
      "Sid": "LambdaBasicExecution",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:ap-south-1:603433800200:*"
    }
  ]
}